{
  "name": "feedback-chat-twitch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "download-badges": "node scripts/download-badges.js",
    "generate:og": "tsx --tsconfig tsconfig.app.json src/generate-og.tsx",
    "generate:og:watch": "tsx watch --tsconfig tsconfig.app.json src/generate-og.tsx",
    "build": "tsc -b && vite build",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:github": "oxlint --format=github",
    "postinstall": "pnpm download-badges && pnpm generate:og",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "marked-react": "^4.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "sharp-ico": "^0.1.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "tmi.js": "^1.8.5"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/tmi.js": "^1.8.6",
    "@vitejs/plugin-react": "6.0.2",
    "globals": "^16.5.0",
    "oxfmt": "0.50.0",
    "oxlint": "1.65.0",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.48.0",
    "vite": "8.0.13"
  },
  "packageManager": "pnpm@11.3.0"
}
